<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.custom.gauge-chart" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">Semi-Circular Gauge Chart</name>
    <description>A configurable semi-circular gauge chart (speedometer style) extension for Tableau dashboards. Supports multiple color ranges, tooltips, click-to-filter interactivity, and full visual customization.</description>
    <author name="Custom Extension" email="extensions@example.com" organization="Custom Extensions" website="https://example.com"/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>https://arp001.github.io/viz-extension/gauge.html</url>
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
    <context-menu>
      <configure-context-menu-item />
    </context-menu>
  </dashboard-extension>
</manifest>
